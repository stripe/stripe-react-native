ws_dir = Pathname.new(__dir__)
ws_dir = ws_dir.parent until
  File.exist?("#{ws_dir}/node_modules/react-native-test-app/test_app.rb") ||
  ws_dir.expand_path.to_s == '/'
require "#{ws_dir}/node_modules/react-native-test-app/test_app.rb"
require 'securerandom'

workspace 'example.xcworkspace'
use_frameworks! :linkage => :dynamic

def build_setting_values(value)
  return [] if value.nil?
  return value if value.is_a?(Array)

  value.split(' ')
end

def add_spm_build_settings_to_target(target, module_map_names:)
  search_paths = [
    '${SYMROOT}/${CONFIGURATION}${EFFECTIVE_PLATFORM_NAME}/',
    '${SYMROOT}/${CONFIGURATION}${EFFECTIVE_PLATFORM_NAME}/PackageFrameworks',
  ]
  framework_search_path = '${SYMROOT}/${CONFIGURATION}${EFFECTIVE_PLATFORM_NAME}/PackageFrameworks'
  module_map_dir = '$(OBJROOT)/GeneratedModuleMaps$(EFFECTIVE_PLATFORM_NAME)'

  target.build_configurations.each do |config|
    [target.build_settings(config.name), config.build_settings].each do |build_settings|
      swift_include_paths = build_setting_values(build_settings['SWIFT_INCLUDE_PATHS'])
      swift_include_paths << '$(inherited)' if swift_include_paths.empty?
      search_paths.each do |search_path|
        swift_include_paths << search_path unless swift_include_paths.include?(search_path)
      end
      build_settings['SWIFT_INCLUDE_PATHS'] = swift_include_paths

      framework_search_paths = build_setting_values(build_settings['FRAMEWORK_SEARCH_PATHS'])
      framework_search_paths << '$(inherited)' if framework_search_paths.empty?
      framework_search_paths << framework_search_path unless framework_search_paths.include?(framework_search_path)
      build_settings['FRAMEWORK_SEARCH_PATHS'] = framework_search_paths

      swift_flags = build_setting_values(build_settings['OTHER_SWIFT_FLAGS'])
      swift_flags << '$(inherited)' if swift_flags.empty?
      module_map_names.each do |name|
        module_map_flag = "-fmodule-map-file=#{module_map_dir}/#{name}.modulemap"
        next if swift_flags.include?(module_map_flag)

        swift_flags << '-Xcc'
        swift_flags << module_map_flag
      end
      build_settings['OTHER_SWIFT_FLAGS'] = swift_flags
    end
  end
end

def add_spm_build_settings_to_xcconfig(path, module_map_names:)
  return unless File.exist?(path)

  search_paths = [
    '${SYMROOT}/${CONFIGURATION}${EFFECTIVE_PLATFORM_NAME}/',
    '${SYMROOT}/${CONFIGURATION}${EFFECTIVE_PLATFORM_NAME}/PackageFrameworks',
  ]
  framework_search_path = '${SYMROOT}/${CONFIGURATION}${EFFECTIVE_PLATFORM_NAME}/PackageFrameworks'
  module_map_dir = '$(OBJROOT)/GeneratedModuleMaps$(EFFECTIVE_PLATFORM_NAME)'
  module_map_flags = module_map_names.map do |name|
    "-Xcc -fmodule-map-file=#{module_map_dir}/#{name}.modulemap"
  end

  lines = File.readlines(path, chomp: true)
  setting_values = {
    'SWIFT_INCLUDE_PATHS' => ['$(inherited)', *search_paths],
    'FRAMEWORK_SEARCH_PATHS' => ['$(inherited)', framework_search_path],
  }
  setting_values['OTHER_SWIFT_FLAGS'] = ['$(inherited)', *module_map_flags] unless module_map_flags.empty?

  setting_values.each do |setting, values|
    line_index = lines.index { |line| line.start_with?("#{setting} =") }
    existing_values = line_index.nil? ? [] : lines[line_index].split(' = ', 2).last.split(' ')
    values.each do |value|
      existing_values << value unless existing_values.include?(value)
    end

    line = "#{setting} = #{existing_values.join(' ')}"
    if line_index.nil?
      lines << line
    else
      lines[line_index] = line
    end
  end

  File.write(path, "#{lines.join("\n")}\n")
end

def add_spm_build_settings_to_target_support_files(installer, target_name:, xcconfig_names:, module_map_names:)
  target_support_dir = installer.sandbox.root + "Target Support Files/#{target_name}"
  xcconfig_names.each do |xcconfig_name|
    add_spm_build_settings_to_xcconfig(target_support_dir + xcconfig_name, module_map_names: module_map_names)
  end
end

def add_framework_link_flags_to_xcconfig(path, framework_names:)
  return unless File.exist?(path)

  lines = File.readlines(path, chomp: true)
  line_index = lines.index { |line| line.start_with?('OTHER_LDFLAGS =') }
  existing_values = line_index.nil? ? ['$(inherited)'] : lines[line_index].split(' = ', 2).last.split(' ')
  framework_names.each do |framework_name|
    quoted_framework_name = "\"#{framework_name}\""
    next if existing_values.include?(quoted_framework_name)

    existing_values << '-framework'
    existing_values << quoted_framework_name
  end

  line = "OTHER_LDFLAGS = #{existing_values.join(' ')}"
  if line_index.nil?
    lines << line
  else
    lines[line_index] = line
  end

  File.write(path, "#{lines.join("\n")}\n")
end

def add_framework_link_flags_to_target_support_files(installer, target_name:, framework_names:)
  target_support_dir = installer.sandbox.root + "Target Support Files/#{target_name}"
  Dir.glob("#{target_support_dir}/*.xcconfig").each do |xcconfig|
    add_framework_link_flags_to_xcconfig(xcconfig, framework_names: framework_names)
  end
end

def available_project_uuid(project, used_uuids = nil)
  used_uuids ||= project.objects_by_uuid.keys
  uuid = SecureRandom.hex(12).upcase
  uuid = SecureRandom.hex(12).upcase while used_uuids.include?(uuid)
  uuid
end

def restore_project_object_graph(project)
  visited = {}
  visit = lambda do |object|
    return if object.nil? || visited[object.object_id]

    visited[object.object_id] = true
    project.objects_by_uuid[object.uuid] = object if object.respond_to?(:uuid)

    object.to_one_attributes.each do |attribute|
      visit.call(attribute.get_value(object))
    end
    object.to_many_attributes.each do |attribute|
      attribute.get_value(object).each { |value| visit.call(value) }
    end
  end

  visit.call(project.root_object)
end

def normalize_spm_product_dependency_uuids(project)
  dependency_class = Xcodeproj::Project::Object::XCSwiftPackageProductDependency
  dependencies = project.targets.select { |target| target.respond_to?(:package_product_dependencies) }
                       .flat_map(&:package_product_dependencies)
                       .select do |dependency|
    dependency.is_a?(dependency_class)
  end.uniq

  root_uuid = project.root_object.uuid
  used_uuids = project.objects.map(&:uuid) - dependencies.map(&:uuid)
  dependencies.each do |dependency|
    if dependency.uuid != root_uuid && project.objects_by_uuid[dependency.uuid].equal?(dependency)
      project.objects_by_uuid.delete(dependency.uuid)
    end

    uuid = available_project_uuid(project, used_uuids)

    dependency.instance_variable_set(:@uuid, uuid)
    project.objects_by_uuid[uuid] = dependency
    used_uuids << uuid
  end

  restore_project_object_graph(project)
end

def add_spm_resource_bundle_copy_phase(test_target)
  phase_name = '[SPM] Copy Stripe Resource Bundles'
  phase = test_target.shell_script_build_phases.find { |build_phase| build_phase.name == phase_name }
  unless phase
    phase = Xcodeproj::Project::Object::PBXShellScriptBuildPhase.new(
      test_target.project,
      available_project_uuid(test_target.project)
    )
    phase.initialize_defaults
    phase.name = phase_name
    test_target.build_phases << phase
  end

  phase.shell_path = '/bin/sh'
  phase.show_env_vars_in_log = '0'
  phase.shell_script = <<~'SCRIPT'
    set -e

    strip_to_english_localizations() {
      destination_bundle="$1"
      for localized_dir in "$destination_bundle"/*.lproj; do
        [ -d "$localized_dir" ] || continue

        case "$(basename "$localized_dir")" in
          en.lproj|Base.lproj)
            ;;
          *)
            rm -rf "$localized_dir"
            ;;
        esac
      done
    }

    frameworks_dirs="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH} ${BUILT_PRODUCTS_DIR}/PackageFrameworks"
    for bundle in "${BUILT_PRODUCTS_DIR}"/Stripe_*.bundle; do
      [ -d "$bundle" ] || continue

      bundle_name="$(basename "$bundle")"
      module_name="${bundle_name#Stripe_}"
      module_name="${module_name%.bundle}"
      copied=false

      for frameworks_dir in $frameworks_dirs; do
        [ -d "$frameworks_dir" ] || continue

        for framework in "$frameworks_dir/${module_name}.framework" "$frameworks_dir/${module_name}_"*.framework; do
          [ -d "$framework" ] || continue

          rsync -a --delete "$bundle" "$framework/"
          strip_to_english_localizations "$framework/$bundle_name"
          copied=true

          if [ "${CODE_SIGNING_ALLOWED:-}" != "NO" ] && [ -n "${EXPANDED_CODE_SIGN_IDENTITY:-}" ]; then
            /usr/bin/codesign --force --sign "${EXPANDED_CODE_SIGN_IDENTITY}" --preserve-metadata=identifier,entitlements "$framework"
          fi
        done
      done

      if [ "$copied" = false ]; then
        rsync -a --delete "$bundle" "${TARGET_BUILD_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}/"
        strip_to_english_localizations "${TARGET_BUILD_DIR}/${UNLOCALIZED_RESOURCES_FOLDER_PATH}/$bundle_name"
      fi
    done
  SCRIPT
end

def add_spm_dependencies_to_test_target(installer, source_target_name:, test_target_name:, module_map_names:)
  project = installer.pods_project
  source_target = project.targets.find { |target| target.name == source_target_name }
  test_target = project.targets.find { |target| target.name == test_target_name }

  return if source_target.nil? || test_target.nil?
  return unless source_target.respond_to?(:package_product_dependencies) &&
                test_target.respond_to?(:package_product_dependencies)

  source_dependencies = source_target.package_product_dependencies.select do |dependency|
    dependency.respond_to?(:package) && dependency.package
  end
  return if source_dependencies.empty?

  source_dependencies.each do |dependency|
    existing_dependency = test_target.package_product_dependencies.find do |test_dependency|
      test_dependency.package == dependency.package &&
        test_dependency.product_name == dependency.product_name
    end
    next unless existing_dependency.nil?

    test_target.package_product_dependencies << dependency
  end

  add_spm_build_settings_to_target(source_target, module_map_names: [])
  add_spm_build_settings_to_target(test_target, module_map_names: module_map_names)
  add_spm_build_settings_to_target_support_files(
    installer,
    target_name: source_target_name,
    xcconfig_names: [
      "#{source_target_name}.debug.xcconfig",
      "#{source_target_name}.release.xcconfig",
    ],
    module_map_names: []
  )
  add_spm_build_settings_to_target_support_files(
    installer,
    target_name: source_target_name,
    xcconfig_names: [
      "#{source_target_name}.unit-tests.debug.xcconfig",
      "#{source_target_name}.unit-tests.release.xcconfig",
    ],
    module_map_names: module_map_names
  )

  add_spm_resource_bundle_copy_phase(test_target)
  normalize_spm_product_dependency_uuids(project)

  Pod::UI.puts "[SPM] Added #{source_dependencies.map(&:product_name).join(', ')} to #{test_target_name}"
end

# Use prebuilt RN.
ENV['RCT_USE_RN_DEP'] = '1'
ENV['RCT_USE_PREBUILT_RNCORE'] = '1'

new_arch_enabled = ENV['NEW_ARCH_ENABLED'].nil? ? true : ENV['NEW_ARCH_ENABLED'] == 'true'

options = {
  :bridgeless_enabled => new_arch_enabled,
  :fabric_enabled =>  new_arch_enabled,
  :hermes_enabled => true,
  :post_install => lambda do |installer|
    add_spm_dependencies_to_test_target(
      installer,
      source_target_name: 'stripe-react-native',
      test_target_name: 'stripe-react-native-Unit-Tests',
      module_map_names: [
        'Stripe',
        'Stripe3DS2',
        'StripeApplePay',
        'StripeCameraCore',
        'StripeCore',
        'StripeCryptoOnramp',
        'StripeFinancialConnections',
        'StripeIdentity',
        'StripeIssuing',
        'StripePaymentSheet',
        'StripePayments',
        'StripePaymentsUI',
        'StripeUICore',
      ]
    )
    add_framework_link_flags_to_target_support_files(
      installer,
      target_name: 'ReactTestApp-DevSupport',
      framework_names: [
        'React',
        'ReactNativeDependencies',
        'hermes',
      ]
    )
    [
      'react-native-safe-area-context',
      'RNCAsyncStorage',
      'RNCPicker',
      'stripe-react-native',
    ].each do |target_name|
      add_framework_link_flags_to_target_support_files(
        installer,
        target_name: target_name,
        framework_names: [
          'React',
        ]
      )
    end
  end,
}

use_test_app! options do |target|
  pod 'stripe-react-native', path: '../node_modules/@stripe/stripe-react-native', testspecs: ['Tests']
  pod 'stripe-react-native/Onramp', path: '../node_modules/@stripe/stripe-react-native'
end
